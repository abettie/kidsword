# Slack通知スクリプト用の環境変数サンプル
# このファイルを .env にコピーして実際の値を設定してください。
#   cp .env_sample .env

# ----------------------------------------
# 必須
# ----------------------------------------

# Bot User OAuth Token（Slack App の "OAuth & Permissions" ページで取得）
SLACK_BOT_TOKEN=xoxb-your-token-here

# 投稿先チャンネルID（例: C01234ABCDE）
# チャンネルを右クリック → "チャンネルの詳細を表示" → 最下部に表示されます
SLACK_CHANNEL_ID=C01234ABCDE

# ----------------------------------------
# オプション
# ----------------------------------------

# 総タイムアウト秒数（デフォルト: 1800 = 30分）
# SLACK_MAX_WAIT=1800

# 初回ポーリング間隔秒数（デフォルト: 5）
# SLACK_INITIAL_INTERVAL=5

# ポーリング間隔の最大秒数（デフォルト: 300 = 5分）
# SLACK_MAX_INTERVAL=300
